<meta charset="utf-8">
<title>ContentAgent — Feature List</title>
<style>
body { font-family: Calibri, Arial, sans-serif; font-size: 11pt; line-height: 1.5; margin: 2cm; }
h1 { font-size: 22pt; color: #1a1a1a; border-bottom: 2px solid #333; padding-bottom: 6pt; }
h2 { font-size: 16pt; color: #2c3e50; margin-top: 18pt; }
h3 { font-size: 13pt; color: #34495e; margin-top: 14pt; }
ul { margin-left: 20pt; }
li { margin-bottom: 3pt; }
code { font-family: Consolas, monospace; font-size: 10pt; background: #f4f4f4; padding: 1pt 3pt; }
pre { font-family: Consolas, monospace; font-size: 9pt; background: #f4f4f4; padding: 10pt; border: 1px solid #ddd; white-space: pre-wrap; }
hr { border: none; border-top: 1px solid #ccc; margin: 18pt 0; }
b { color: #1a6b3a; }
</style>
